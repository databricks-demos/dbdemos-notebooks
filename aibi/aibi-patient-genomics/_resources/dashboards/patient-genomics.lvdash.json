                "x": {
                  "fieldName": "survival_lift",
                  "scale": {
                    "type": "quantitative"
                  },
                  "displayName": "Survival lift vs standard of care (pts)"
                },
                "color": {
                  "fieldName": "verdict",
                  "scale": {
                    "type": "categorical",
                    "mappings": [
                      {
                        "value": "Benefits",
                        "color": "#00A972"
                      },
                      {
                        "value": "No effect",
                        "color": "#9AA7B4"
                      },
                      {
                        "value": "Not indicated",
                        "color": "#E92828"
                      }
                    ]
                  },
                  "displayName": ""
                }
              },
              "frame": {
                "showTitle": true,
                "title": "Survival lift by cancer site \u2014 where OncoTarget-1 helps (green), does nothing (grey), or harms (red)"
              }
            }
          },
          "position": {
            "x": 0,
            "y": 5,
            "width": 7,
            "height": 7
          }
        },
        {
          "widget": {
            "name": "umap_map",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_umap",
                  "fields": [
                    {
                      "name": "c1",
                      "expression": "`c1`"
                    },
                    {
                      "name": "c2",
                      "expression": "`c2`"
                    },
                    {
                      "name": "cluster",
                      "expression": "`cluster`"
                    },
                    {
                      "name": "tissue",
                      "expression": "`tissue`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "scatter",
              "encodings": {
