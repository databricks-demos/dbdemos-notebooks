{
  "datasets": [
    {
      "name": "ds_metrics",
      "displayName": "Sales metrics",
      "asset_name": "main.dbdemos_aibi_sales_pipeline_review.metrics_sales"
    },
    {
      "name": "ds_target",
      "displayName": "Quarter attainment vs target (AI forecast)",
      "queryLines": [
        "WITH maxd AS (SELECT max(order_date) md FROM main.dbdemos_aibi_sales_pipeline_review.orders_enriched),\n",
        "daily AS (\n",
        "  SELECT order_date AS d, sum(revenue) AS rev\n",
        "  FROM main.dbdemos_aibi_sales_pipeline_review.orders_enriched\n",
        "  WHERE order_date >= DATE'2026-04-01' AND order_date <= (SELECT md FROM maxd)\n",
        "  GROUP BY 1),\n",
        "fc AS (SELECT d, rev_forecast FROM AI_FORECAST(TABLE(SELECT d, rev FROM daily), horizon => '2026-06-30', time_col => 'd', value_col => 'rev')),\n",
        "qtd AS (SELECT sum(rev) actual FROM daily),\n",
        "rest AS (SELECT sum(rev_forecast) fcast FROM fc WHERE d > (SELECT md FROM maxd)),\n",
        "tgt AS (SELECT target_revenue FROM main.dbdemos_aibi_sales_pipeline_review.sales_targets WHERE quarter_start = DATE'2026-04-01')\n",
        "SELECT (SELECT actual FROM qtd) AS qtd_actual,\n",
        "       (SELECT target_revenue FROM tgt) AS target,\n",
        "       (SELECT actual FROM qtd) + COALESCE((SELECT fcast FROM rest),0) AS projected_quarter,\n",
        "       ((SELECT actual FROM qtd) + COALESCE((SELECT fcast FROM rest),0)) / (SELECT target_revenue FROM tgt) AS attainment_pct"
      ]
    },
    {
      "name": "ds_forecast",
      "displayName": "Weekly revenue + AI forecast",
      "queryLines": [
        "WITH maxd AS (SELECT max(order_date) md FROM main.dbdemos_aibi_sales_pipeline_review.orders_enriched),\n",
        "weekly AS (\n",
        "  SELECT date_trunc('week', order_date) AS w, sum(revenue) AS rev\n",
        "  FROM main.dbdemos_aibi_sales_pipeline_review.orders_enriched\n",
        "  WHERE order_date >= DATE'2025-09-01' AND order_date < date_trunc('week', (SELECT md FROM maxd))\n",
        "  GROUP BY 1),\n",
        "fc AS (SELECT w, rev_forecast, rev_lower, rev_upper FROM AI_FORECAST(TABLE(SELECT w, rev FROM weekly), horizon => '2026-08-31', time_col => 'w', value_col => 'rev')),\n",
        "actuals AS (SELECT w AS week, rev AS actual_revenue, CAST(NULL AS DOUBLE) AS forecast_revenue, CAST(NULL AS DOUBLE) AS rev_lower, CAST(NULL AS DOUBLE) AS rev_upper FROM weekly WHERE w <> (SELECT max(w) FROM weekly)),\n",
        "bridge AS (SELECT w AS week, rev, rev, rev, rev FROM weekly WHERE w = (SELECT max(w) FROM weekly)),\n",
        "forecast AS (SELECT w AS week, CAST(NULL AS DOUBLE), rev_forecast, rev_lower, rev_upper FROM fc)\n",
        "SELECT * FROM actuals UNION ALL SELECT * FROM bridge UNION ALL SELECT * FROM forecast ORDER BY week"
      ]
    },
    {
      "name": "ds_region_trend",
      "displayName": "Daily revenue by region",
      "queryLines": [
        "SELECT order_date AS day, region,\n",
        "  sum(revenue) AS revenue\n",
        "FROM main.dbdemos_aibi_sales_pipeline_review.orders_enriched\n",
        "WHERE order_date >= DATE'2026-02-01' AND order_date < (SELECT max(order_date) FROM main.dbdemos_aibi_sales_pipeline_review.orders_enriched)\n",
        "GROUP BY 1,2 ORDER BY day"
      ]
    },
    {
      "name": "ds_emea_line",
      "displayName": "EMEA weekly revenue by product line",
      "queryLines": [
        "SELECT date_trunc('week', order_date) AS week, product_line,\n",
        "  sum(revenue) AS revenue\n",
        "FROM main.dbdemos_aibi_sales_pipeline_review.orders_enriched\n",
        "WHERE region = 'EMEA' AND order_date >= DATE'2026-01-01'\n",
        "GROUP BY 1,2 ORDER BY week"
      ]
    },
    {
      "name": "ds_launch",
      "displayName": "Product launches (PIM)",
      "queryLines": [
        "SELECT product_line, region, launch_date, launch_name, description\n",
        "FROM main.dbdemos_aibi_sales_pipeline_review.product_launches\n",
        "WHERE region = 'EMEA' OR region = 'Global'\n",
        "ORDER BY launch_date"
      ]
    }
  ],
