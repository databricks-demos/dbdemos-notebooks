{
  "datasets": [
    {
      "name": "ds_metrics",
      "displayName": "Support metrics",
      "asset_name": "main.dbdemos_aibi_customer_support.support_metrics"
    },
    {
      "name": "ds_forecast",
      "displayName": "Weekly human-handled volume + forecast",
      "queryLines": [
        "WITH cutoff AS (\n",
        "  SELECT DATE_TRUNC('WEEK', MAX(opened_at)) AS last_week_start\n",
        "  FROM main.dbdemos_aibi_customer_support.support_cases_enriched\n",
        "),\n",
        "original_table AS (\n",
        "  SELECT DATE_TRUNC('WEEK', opened_at) AS opened_at, COUNT(*) AS count\n",
        "  FROM main.dbdemos_aibi_customer_support.support_cases_enriched, cutoff\n",
        "  WHERE ai_handled = false\n",
        "    AND (size(:region_filter) = 0 OR array_contains(:region_filter, region_name))\n",
        "    AND DATE_TRUNC('WEEK', opened_at) < cutoff.last_week_start\n",
        "  GROUP BY 1\n",
        "),\n",
        "dates AS (SELECT MAX(opened_at) AS max_date_column, MIN(opened_at) AS min_date_column FROM original_table),\n",
        "forecast_table AS (\n",
        "  SELECT opened_at, count_forecast, count_upper, count_lower, NULL AS count\n",
        "  FROM AI_FORECAST(TABLE(original_table),\n",
        "    horizon => (SELECT max_date_column + MAKE_DT_INTERVAL(CAST(FLOOR(DATEDIFF(max_date_column, min_date_column)*0.25) AS INT),0,0,0) FROM dates),\n",
        "    time_col => 'opened_at', value_col => 'count')\n",
        ")\n",
        "SELECT opened_at, count_forecast, count_upper, count_lower, count FROM forecast_table\n",
        "UNION ALL\n",
        "SELECT opened_at, NULL, NULL, NULL, count FROM original_table\n",
        "UNION ALL\n",
        "SELECT max_date_column, count, count, count, count FROM dates JOIN original_table ON original_table.opened_at = dates.max_date_column"
      ],
      "parameters": [
        {
          "displayName": "Region",
          "keyword": "region_filter",
          "dataType": "STRING",
          "complexType": "MULTI",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": []
            }
          }
        }
      ]
    },
    {
      "name": "ds_usage",
      "displayName": "AI assistant usage",
      "queryLines": [
        "SELECT DATE_TRUNC('MONTH', usage_date) AS month, SUM(ai_queries) AS ai_queries, SUM(ai_deflections) AS ai_deflections, SUM(ai_compute_cost) AS ai_compute_cost ",
        "FROM main.dbdemos_aibi_customer_support.ai_assistant_usage GROUP BY 1 ORDER BY 1"
      ]
    },
    {
      "name": "ds_usage_total",
      "displayName": "AI usage totals",
      "queryLines": [
        "SELECT SUM(ai_queries) AS ai_queries, SUM(ai_deflections) AS ai_deflections, SUM(ai_compute_cost) AS ai_compute_cost FROM main.dbdemos_aibi_customer_support.ai_assistant_usage"
      ]
    },
    {
      "name": "ds_releases",
      "displayName": "AI Copilot releases",
      "queryLines": [
        "SELECT version, release_date, status, capability_summary, release_notes FROM main.dbdemos_aibi_customer_support.ai_assistant_releases ORDER BY release_date"
      ]
    }
  ],
