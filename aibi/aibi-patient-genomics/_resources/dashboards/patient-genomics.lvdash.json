                  "datasetName": "ds_lift",
                  "fields": [
                    {
                      "name": "tissue",
                      "expression": "`tissue`"
                    },
                    {
                      "name": "survival_lift",
                      "expression": "`survival_lift`"
                    },
                    {
                      "name": "verdict",
                      "expression": "`verdict`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "y": {
                  "fieldName": "tissue",
                  "scale": {
                    "type": "categorical"
                  },
                  "displayName": "Cancer site"
