{
  "datasets": [
    {
      "name": "ds_metrics",
      "displayName": "Genomics metrics",
      "asset_name": "main.dbdemos_aibi_hls_genomics.genomics_metrics"
    },
    {
      "name": "ds_kpi_treated",
      "displayName": "Survival treated",
      "queryLines": [
        "SELECT survival_pct FROM main.dbdemos_aibi_hls_genomics.arm_summary WHERE treatment_arm='OncoTarget-1'"
      ]
    },
    {
      "name": "ds_kpi_soc",
      "displayName": "Survival SoC",
      "queryLines": [
        "SELECT survival_pct FROM main.dbdemos_aibi_hls_genomics.arm_summary WHERE treatment_arm='Standard of care'"
      ]
    },
    {
      "name": "ds_kpi_patients",
      "displayName": "Patients",
      "queryLines": [
        "SELECT count(*) AS patients FROM main.dbdemos_aibi_hls_genomics.patient_cohort"
      ]
    },
    {
      "name": "ds_kpi_lift",
      "displayName": "Responder lift",
      "queryLines": [
        "SELECT round(max(CASE WHEN treatment_arm='OncoTarget-1' THEN survival_pct END)\n",
        "  - max(CASE WHEN treatment_arm='Standard of care' THEN survival_pct END),1) AS lift\n",
        "FROM main.dbdemos_aibi_hls_genomics.breast_deepdive WHERE subgroup='Responder subtype'"
      ]
    },
    {
      "name": "ds_arm",
      "displayName": "Survival by arm",
      "queryLines": [
        "SELECT treatment_arm, survival_pct, patients FROM main.dbdemos_aibi_hls_genomics.arm_summary ORDER BY treatment_arm"
      ]
    },
    {
      "name": "ds_curve",
      "displayName": "Survival curve (overall)",
      "queryLines": [
        "SELECT month, treatment_arm, pct_surviving FROM main.dbdemos_aibi_hls_genomics.survival_curve ORDER BY month, treatment_arm"
      ]
    },
    {
      "name": "ds_curve_resp",
      "displayName": "Survival curve (responder subtype)",
      "queryLines": [
        "SELECT month, treatment_arm, pct_surviving FROM main.dbdemos_aibi_hls_genomics.survival_curve_responder ORDER BY month, treatment_arm"
      ]
    },
    {
      "name": "ds_spark_treated",
      "displayName": "Treated survival trend (sparkline)",
      "queryLines": [
        "SELECT month, pct_surviving FROM main.dbdemos_aibi_hls_genomics.survival_curve WHERE treatment_arm='OncoTarget-1' ORDER BY month"
      ]
    },
    {
      "name": "ds_spark_soc",
      "displayName": "SoC survival trend (sparkline)",
      "queryLines": [
        "SELECT month, pct_surviving FROM main.dbdemos_aibi_hls_genomics.survival_curve WHERE treatment_arm='Standard of care' ORDER BY month"
      ]
    },
    {
      "name": "ds_site",
      "displayName": "Survival by cancer site x arm",
      "queryLines": [
        "SELECT tissue, treatment_arm, survival_pct, patients FROM main.dbdemos_aibi_hls_genomics.survival_by_arm\n",
        "WHERE patients > 80 ORDER BY tissue, treatment_arm"
      ]
    },
    {
      "name": "ds_lift",
      "displayName": "Survival lift by cancer site",
      "queryLines": [
        "SELECT tissue, survival_lift, patients,\n",
        "  CASE WHEN survival_lift >= 3 THEN 'Benefits' WHEN survival_lift <= -3 THEN 'Not indicated' ELSE 'No effect' END AS verdict\n",
        "FROM main.dbdemos_aibi_hls_genomics.lift_by_site ORDER BY survival_lift DESC"
      ]
    },
    {
      "name": "ds_umap",
      "displayName": "UMAP molecular map",
      "queryLines": [
        "SELECT c1, c2, tissue,\n",
        "  CASE WHEN responder_subtype THEN 'Responder subtype' ELSE tissue END AS cluster,\n",
        "  treatment_arm, survived_24mo\n",
        "FROM main.dbdemos_aibi_hls_genomics.patient_cohort\n",
        "WHERE c1 IS NOT NULL AND tissue IN ('Breast, NOS','Kidney, NOS','Upper lobe, lung','Thyroid gland','Prostate gland','Liver','Ovary','Skin, NOS')"
      ]
    },
    {
      "name": "ds_breast",
      "displayName": "Breast deep-dive",
      "queryLines": [
        "SELECT subgroup, treatment_arm, survival_pct, patients FROM main.dbdemos_aibi_hls_genomics.breast_deepdive ORDER BY subgroup, treatment_arm"
      ]
    },
    {
      "name": "ds_umap_breast",
      "displayName": "UMAP breast responders",
      "queryLines": [
        "SELECT c1, c2, CASE WHEN responder_subtype THEN 'Responder subtype' ELSE 'Other breast' END AS subgroup, treatment_arm, survived_24mo\n",
        "FROM main.dbdemos_aibi_hls_genomics.patient_cohort WHERE tissue='Breast, NOS' AND c1 IS NOT NULL"
      ]
    },
    {
      "name": "ds_responder_demo",
      "displayName": "Responder demographics",
      "queryLines": [
        "SELECT race, count(*) patients, round(avg(age)) avg_age\n",
        "FROM main.dbdemos_aibi_hls_genomics.patient_cohort WHERE responder_subtype GROUP BY 1 HAVING patients>10 ORDER BY patients DESC"
      ]
    },
    {
      "name": "ds_patients",
      "displayName": "Patient table",
      "queryLines": [
        "SELECT case_id, primary_diagnosis, gender, age, treatment_arm,\n",
        "  CASE WHEN survived_24mo THEN 'Survived' ELSE 'Deceased' END AS outcome_24mo, months_survived\n",
        "FROM main.dbdemos_aibi_hls_genomics.patient_cohort WHERE tissue='Breast, NOS' AND responder_subtype ORDER BY treatment_arm, months_survived DESC LIMIT 200"
      ]
    }
  ],
  "pages": [
    {
      "name": "evidence",
      "displayName": "Real-world evidence",
      "pageType": "PAGE_TYPE_CANVAS",
      "layoutVersion": "GRID_V1",
      "layout": [
        {
          "widget": {
            "name": "title",
            "multilineTextboxSpec": {
              "lines": [
                "# OncoTarget-1 \u2014 it works\u2026 but not everywhere. *Where* should we use it?\n\nWe rolled out a new targeted therapy across a real 10,000-patient oncology cohort. Overall, treated patients survive better \u2014 but the benefit is **wildly uneven**: a near-miracle in some cancers, nothing in others, and in a couple it may even do harm. The chart below ranks every cancer by survival lift. The obvious follow-up: *what separates the responders from the rest?* (Answer on page 2 \u2014 and it's molecular.)"
              ]
            }
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 12,
            "height": 2
          }
        },
        {
          "widget": {
            "name": "kpi_patients",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_kpi_patients",
                  "fields": [
                    {
                      "name": "patients",
                      "expression": "`patients`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "patients",
                  "displayName": "Patients",
                  "format": {
                    "type": "number-plain",
                    "decimalPlaces": {
                      "type": "max",
                      "places": 0
                    }
                  }
                }
              },
              "frame": {
                "showTitle": true,
                "title": "Patients in cohort"
              }
            }
          },
          "position": {
            "x": 0,
            "y": 2,
            "width": 3,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "kpi_treated",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_spark_treated",
                  "fields": [
                    {
                      "name": "pct_surviving",
                      "expression": "`pct_surviving`"
                    },
                    {
                      "name": "month",
                      "expression": "`month`"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "pct_surviving",
                  "displayName": "Treated",
                  "format": {
                    "type": "number-plain",
                    "decimalPlaces": {
                      "type": "max",
                      "places": 1
                    }
                  },
                  "formatTemplate": "{{ @formatted }}%",
                  "color": {
                    "default": "#077A9D"
                  }
                },
                "period": {
                  "fieldName": "month"
                }
              },
              "frame": {
                "showTitle": true,
                "title": "OncoTarget-1 survival (24mo)"
              }
            }
          },
          "position": {
            "x": 3,
            "y": 2,
            "width": 3,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "kpi_soc",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_spark_soc",
                  "fields": [
                    {
                      "name": "pct_surviving",
                      "expression": "`pct_surviving`"
                    },
                    {
                      "name": "month",
                      "expression": "`month`"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "pct_surviving",
                  "displayName": "Standard",
                  "format": {
                    "type": "number-plain",
                    "decimalPlaces": {
                      "type": "max",
                      "places": 1
                    }
                  },
                  "formatTemplate": "{{ @formatted }}%",
                  "color": {
                    "default": "#FCA4A1"
                  }
                },
                "period": {
                  "fieldName": "month"
                }
              },
              "frame": {
                "showTitle": true,
                "title": "Standard of care survival (24mo)"
              }
            }
          },
          "position": {
            "x": 6,
            "y": 2,
            "width": 3,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "kpi_lift",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_kpi_lift",
                  "fields": [
