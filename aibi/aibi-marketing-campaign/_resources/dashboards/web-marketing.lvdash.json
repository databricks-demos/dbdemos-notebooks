{
  "datasets": [
    {
      "name": "ds_metrics",
      "displayName": "Campaign metrics",
      "asset_name": "main.dbdemos_aibi_cme_marketing_campaign.metrics_campaign"
    },
    {
      "name": "ds_forecast",
      "displayName": "Revenue / $ trend + AI forecast",
      "queryLines": [
        "WITH monthly AS (\n",
        "  SELECT date_trunc('month', date) AS month, sum(revenue)/nullif(sum(spend),0) AS rev_per_dollar\n",
        "  FROM main.dbdemos_aibi_cme_marketing_campaign.campaign_performance_enriched\n",
        "  WHERE date < date_trunc('month', (SELECT max(date) FROM main.dbdemos_aibi_cme_marketing_campaign.campaign_performance_enriched))\n",
        "  GROUP BY 1\n",
        "),\n",
        "fc AS (\n",
        "  SELECT month, rev_per_dollar_forecast, rev_per_dollar_lower, rev_per_dollar_upper\n",
        "  FROM AI_FORECAST(TABLE(SELECT month, rev_per_dollar FROM monthly), horizon => '2026-09-01', time_col => 'month', value_col => 'rev_per_dollar')\n",
        "),\n",
        "actuals AS (\n",
        "  SELECT month, rev_per_dollar, CAST(NULL AS DOUBLE) AS rev_per_dollar_forecast, CAST(NULL AS DOUBLE) AS rev_per_dollar_lower, CAST(NULL AS DOUBLE) AS rev_per_dollar_upper\n",
        "  FROM monthly WHERE month <> (SELECT max(month) FROM monthly)\n",
        "),\n",
        "bridge AS (\n",
        "  SELECT month, rev_per_dollar, rev_per_dollar, rev_per_dollar, rev_per_dollar FROM monthly WHERE month = (SELECT max(month) FROM monthly)\n",
        "),\n",
        "forecast AS (\n",
        "  SELECT month, CAST(NULL AS DOUBLE) AS rev_per_dollar, rev_per_dollar_forecast, rev_per_dollar_lower, rev_per_dollar_upper FROM fc\n",
        ")\n",
        "SELECT * FROM actuals UNION ALL SELECT * FROM bridge UNION ALL SELECT * FROM forecast\n",
        "ORDER BY month"
      ]
    },
    {
      "name": "ds_map",
      "displayName": "Performance by market (last 6 months)",
      "queryLines": [
        "SELECT country, latitude, longitude,\n",
        "  sum(spend) AS spend,\n",
        "  sum(revenue)/nullif(sum(spend),0) AS rev_per_dollar\n",
        "FROM main.dbdemos_aibi_cme_marketing_campaign.campaign_performance_enriched\n",
        "WHERE date >= add_months((SELECT max(date) FROM main.dbdemos_aibi_cme_marketing_campaign.campaign_performance_enriched), -6)\n",
        "GROUP BY 1,2,3\n",
        "ORDER BY rev_per_dollar ASC"
      ]
    },
    {
      "name": "ds_damage",
      "displayName": "Damage from the underperforming creative",
      "queryLines": [
        "WITH bad AS (\n",
        "  SELECT sum(spend) AS spend_wasted, sum(clicks) AS clicks, sum(conversions) AS conv,\n",
        "    sum(conversions)/nullif(sum(clicks),0) AS cvr\n",
        "  FROM main.dbdemos_aibi_cme_marketing_campaign.campaign_performance_enriched\n",
        "  WHERE creative_status = 'underperforming'\n",
        "),\n",
        "bench AS (\n",
        "  SELECT sum(conversions)/nullif(sum(clicks),0) AS cvr, sum(revenue)/nullif(sum(conversions),0) AS rev_per_conv\n",
        "  FROM main.dbdemos_aibi_cme_marketing_campaign.campaign_performance_enriched\n",
        "  WHERE channel_name = 'TikTok' AND creative_status = 'active'\n",
        ")\n",
        "SELECT bad.spend_wasted, bad.cvr AS bad_cvr, bench.cvr AS benchmark_cvr,\n",
        "  (bad.clicks * bench.cvr - bad.conv) * bench.rev_per_conv AS lost_revenue\n",
        "FROM bad, bench"
      ]
    },
    {
      "name": "ds_campaign",
      "displayName": "Campaign performance (since Sept)",
      "queryLines": [
        "SELECT campaign_name,\n",
        "  sum(revenue)/nullif(sum(spend),0) AS rev_per_dollar,\n",
        "  CASE WHEN campaign_name = 'Q4 Growth Push' THEN 'Failing' ELSE 'Healthy' END AS health\n",
        "FROM main.dbdemos_aibi_cme_marketing_campaign.campaign_performance_enriched\n",
        "WHERE date >= DATE'2025-09-01'\n",
        "GROUP BY 1\n",
        "ORDER BY rev_per_dollar ASC"
      ]
    },
    {
      "name": "ds_q4_creatives",
      "displayName": "Creatives within Q4 Growth Push",
      "queryLines": [
        "SELECT creative_name,\n",
        "  sum(revenue)/nullif(sum(spend),0) AS rev_per_dollar,\n",
        "  CASE WHEN creative_status = 'underperforming' THEN 'Underperforming' ELSE 'Healthy' END AS health\n",
        "FROM main.dbdemos_aibi_cme_marketing_campaign.campaign_performance_enriched\n",
        "WHERE campaign_name = 'Q4 Growth Push'\n",
        "GROUP BY 1, creative_status\n",
        "ORDER BY rev_per_dollar ASC"
      ]
    }
  ],
