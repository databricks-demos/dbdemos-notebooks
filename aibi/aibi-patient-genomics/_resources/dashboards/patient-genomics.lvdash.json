                      "name": "lift",
                      "expression": "`lift`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "lift",
                  "displayName": "Responder lift",
                  "format": {
                    "type": "number-plain",
                    "decimalPlaces": {
                      "type": "max",
                      "places": 1
                    }
                  },
                  "formatTemplate": "+{{ @formatted }} pts",
                  "color": {
                    "default": "#00A972"
                  }
                }
              },
              "frame": {
                "showTitle": true,
                "title": "Best-responder survival lift"
              }
            }
          },
          "position": {
            "x": 9,
            "y": 2,
            "width": 3,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "lift_bar",
            "queries": [
              {
                "name": "main_query",
