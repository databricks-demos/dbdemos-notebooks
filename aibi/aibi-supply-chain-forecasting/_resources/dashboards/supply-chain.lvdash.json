{
  "datasets": [
    {
      "name": "ds_metrics",
      "displayName": "Demand metrics",
      "asset_name": "main.dbdemos_aibi_mfg_supply_chain_optimization.metrics_demand"
    },
    {
      "name": "ds_component_status",
      "displayName": "Component supply risk",
      "queryLines": [
        "SELECT component_name, plant_name, supplier_name, lead_time_weeks,\n",
        "  on_hand_units, safety_stock_units, weekly_supply_units, avg_weekly_demand,\n",
        "  weeks_of_cover, status\n",
        "FROM main.dbdemos_aibi_mfg_supply_chain_optimization.component_status\n",
        "ORDER BY weeks_of_cover ASC"
      ]
    },
    {
      "name": "ds_kpi",
      "displayName": "Battery Cell risk KPIs (by plant)",
      "queryLines": [
        "WITH maxw AS (SELECT max(week) mw FROM main.dbdemos_aibi_mfg_supply_chain_optimization.demand_enriched),\n",
        "pl AS (SELECT plant_id FROM main.dbdemos_aibi_mfg_supply_chain_optimization.plants WHERE plant_name = :plant),\n",
        "inv AS (SELECT on_hand_units oh FROM main.dbdemos_aibi_mfg_supply_chain_optimization.inventory WHERE component_id = 1 AND plant_id = (SELECT plant_id FROM pl)),\n",
        "cs AS (SELECT weeks_of_cover, lead_time_weeks FROM main.dbdemos_aibi_mfg_supply_chain_optimization.component_status WHERE component_id = 1 AND plant_id = (SELECT plant_id FROM pl)),\n",
        "hist AS (SELECT d.week w, sum(d.demand_units*b.qty_per_unit) dmd FROM main.dbdemos_aibi_mfg_supply_chain_optimization.demand_enriched d JOIN main.dbdemos_aibi_mfg_supply_chain_optimization.bom b ON d.product_id=b.product_id WHERE b.component_id=1 AND ((:plant = 'Rotterdam Plant' AND d.region IN ('EMEA','APAC')) OR (:plant = 'Detroit Plant' AND d.region IN ('AMER','LATAM'))) GROUP BY 1),\n",
        "rr AS (SELECT avg(dmd) run_rate FROM hist WHERE w >= DATE'2026-05-01'),\n",
        "future AS (SELECT explode(sequence((SELECT mw FROM maxw), DATE'2026-09-21', INTERVAL 1 WEEK)) AS w),\n",
        "proj AS (SELECT w, (ROW_NUMBER() OVER (ORDER BY w)) AS k FROM future),\n",
        "bal AS (SELECT w, (SELECT oh FROM inv) - (k-1) * (SELECT run_rate FROM rr) AS onhand FROM proj)\n",
        "SELECT (SELECT weeks_of_cover FROM cs) AS weeks_of_cover,\n",
        "       (SELECT lead_time_weeks FROM cs) AS lead_time_weeks,\n",
        "       (SELECT min(w) FROM bal WHERE onhand <= 0) AS stockout_week,\n",
        "       1 AS components_at_risk"
      ],
      "parameters": [
        {
          "displayName": "Plant",
          "keyword": "plant",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "Rotterdam Plant"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "ds_onhand",
      "displayName": "Component on-hand depletion + forecast",
      "queryLines": [
        "WITH maxw AS (SELECT max(week) mw FROM main.dbdemos_aibi_mfg_supply_chain_optimization.demand_enriched),\n",
        "cmp AS (SELECT component_id FROM main.dbdemos_aibi_mfg_supply_chain_optimization.components WHERE component_name = :component),\n",
        "pl AS (SELECT plant_id FROM main.dbdemos_aibi_mfg_supply_chain_optimization.plants WHERE plant_name = :plant),\n",
        "inv AS (SELECT sum(on_hand_units) oh, sum(safety_stock_units) ss, sum(weekly_supply_units) s FROM main.dbdemos_aibi_mfg_supply_chain_optimization.inventory WHERE component_id = (SELECT component_id FROM cmp) AND plant_id = (SELECT plant_id FROM pl)),\n",
        "hist AS (SELECT d.week w, sum(d.demand_units*b.qty_per_unit) dmd FROM main.dbdemos_aibi_mfg_supply_chain_optimization.demand_enriched d JOIN main.dbdemos_aibi_mfg_supply_chain_optimization.bom b ON d.product_id=b.product_id WHERE b.component_id=(SELECT component_id FROM cmp) AND ((:plant = 'Rotterdam Plant' AND d.region IN ('EMEA','APAC')) OR (:plant = 'Detroit Plant' AND d.region IN ('AMER','LATAM'))) GROUP BY 1),\n",
        "rr AS (SELECT avg(dmd) run_rate FROM hist WHERE w >= DATE'2026-05-01'),\n",
        "future AS (SELECT explode(sequence((SELECT mw FROM maxw), DATE'2026-09-21', INTERVAL 1 WEEK)) AS w),\n",
        "proj AS (SELECT w, (ROW_NUMBER() OVER (ORDER BY w)) AS k FROM future),\n",
        "fcast AS (SELECT w, GREATEST((SELECT oh FROM inv) - (k-1) * (SELECT run_rate FROM rr), 0) AS onhand FROM proj),\n",
        "actuals AS (SELECT w FROM hist WHERE w >= DATE'2026-03-01' AND w < (SELECT mw FROM maxw))\n",
        "SELECT w AS week, CAST((SELECT oh FROM inv) AS DOUBLE) AS actual_on_hand, CAST(NULL AS DOUBLE) AS forecast_on_hand, (SELECT ss FROM inv) AS safety_stock FROM actuals\n",
        "UNION ALL\n",
        "SELECT w AS week, CAST(NULL AS DOUBLE), onhand, (SELECT ss FROM inv) FROM fcast\n",
        "ORDER BY week"
      ],
      "parameters": [
        {
          "displayName": "Component",
          "keyword": "component",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "Battery Cell"
                }
              ]
            }
          }
        },
        {
          "displayName": "Plant",
          "keyword": "plant",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "Rotterdam Plant"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "ds_demand_forecast",
      "displayName": "Total weekly demand + AI forecast",
      "queryLines": [
        "WITH maxw AS (SELECT max(week) mw FROM main.dbdemos_aibi_mfg_supply_chain_optimization.demand_enriched),\n",
        "weekly AS (SELECT week AS w, sum(demand_units) AS demand FROM main.dbdemos_aibi_mfg_supply_chain_optimization.demand_enriched WHERE week < (SELECT mw FROM maxw) GROUP BY 1),\n",
        "fc AS (SELECT w, demand_forecast, demand_lower, demand_upper FROM AI_FORECAST(TABLE(SELECT w, demand FROM weekly), horizon => '2026-08-10', time_col => 'w', value_col => 'demand')),\n",
        "actuals AS (SELECT w AS week, demand AS actual_demand, CAST(NULL AS DOUBLE) AS forecast_demand, CAST(NULL AS DOUBLE) AS demand_lower, CAST(NULL AS DOUBLE) AS demand_upper FROM weekly WHERE w <> (SELECT max(w) FROM weekly)),\n",
        "bridge AS (SELECT w AS week, demand, demand, demand, demand FROM weekly WHERE w = (SELECT max(w) FROM weekly)),\n",
        "forecast AS (SELECT w AS week, CAST(NULL AS DOUBLE), demand_forecast, demand_lower, demand_upper FROM fc)\n",
        "SELECT * FROM actuals UNION ALL SELECT * FROM bridge UNION ALL SELECT * FROM forecast ORDER BY week"
      ]
    },
    {
      "name": "ds_product_trend",
      "displayName": "Weekly demand by product",
      "queryLines": [
        "SELECT week, product_name, sum(demand_units) AS demand\n",
        "FROM main.dbdemos_aibi_mfg_supply_chain_optimization.demand_enriched\n",
        "WHERE week >= DATE'2026-01-01'\n",
        "GROUP BY 1,2 ORDER BY week"
      ]
    },
    {
      "name": "ds_region_demand",
      "displayName": "Weekly demand by region",
      "queryLines": [
        "SELECT date_trunc('week', week) AS week, region, sum(demand_units) AS demand\n",
        "FROM main.dbdemos_aibi_mfg_supply_chain_optimization.demand_enriched\n",
        "WHERE week >= DATE'2026-01-01'\n",
        "GROUP BY 1,2 ORDER BY week"
      ]
    },
    {
      "name": "ds_bom_risk",
      "displayName": "Products using the Battery Cell",
      "queryLines": [
        "SELECT p.product_name, b.qty_per_unit AS battery_cells_per_unit\n",
        "FROM main.dbdemos_aibi_mfg_supply_chain_optimization.bom b\n",
        "JOIN main.dbdemos_aibi_mfg_supply_chain_optimization.products p ON b.product_id = p.product_id\n",
        "WHERE b.component_id = 1\n",
        "ORDER BY b.qty_per_unit DESC"
      ]
    }
  ],
